# Copy to `.env` in the project root (never commit `.env`).
# Environment variables override values in this file.

# --- Required for Demo mode (server-side key) ---
# OpenAI API key. BYO mode can omit this if users supply keys in the UI.
OPENAI_API_KEY=

# --- OpenAI defaults (optional) ---
# Preset key (gpt-4.1, gpt-4.1-mini, gpt-4.1-nano, gpt-4o, gpt-4o-mini) or raw model id.
OPENAI_MODEL=gpt-4o-mini
# Sampling temperature when the client is built without an explicit temperature.
OPENAI_TEMPERATURE=0.2
# Retries for transient OpenAI errors (429, 5xx, timeouts). SDK uses exponential backoff + jitter.
OPENAI_MAX_RETRIES=3

# --- Application (optional) ---
# Logical environment label: dev, test, prod
APP_ENV=dev
# Sidebar Developer diagnostics (dev only; hidden on prod/test deployments)
SHOW_DIAGNOSTICS=false
# Directory for saved mock-interview JSON (relative to process CWD unless absolute).
SESSIONS_DIR=data/sessions
# Progressive streaming for Mock Interview conversational replies (structured flows stay buffered).
ENABLE_STREAMING=true
# Max OpenAI API calls per browser session in Demo access mode (BYO key mode is unlimited).
DEMO_MAX_LLM_CALLS_PER_SESSION=10

# --- Security / guardrails (optional; prefix SECURITY_) ---
SECURITY_MAX_INPUT_LENGTH=8000
SECURITY_OUTPUT_MAX_LENGTH=16000
SECURITY_RATE_LIMIT_MAX_REQUESTS=20
SECURITY_RATE_LIMIT_WINDOW_SECONDS=60
SECURITY_MODERATION_ENABLED=true
SECURITY_PROMPT_INJECTION_STRICT=false
# Reserved for a future optional LLM injection classifier (not active in the app today).
SECURITY_PROMPT_INJECTION_CLASSIFIER_ENABLED=false
SECURITY_CV_MAX_FILE_BYTES=5242880
SECURITY_CV_MAX_TEXT_CHARS=20000
